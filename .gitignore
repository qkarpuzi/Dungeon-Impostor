# =============================
# Visual Studio / IDE
# =============================
.vs/
*.sln
*.suo
*.user
*.userprefs
*.opensdf
*.sdf
*.VC.db
*.VC.opendb
.vsconfig

# =============================
# Compiled binaries
# =============================
Binaries/
Build/
*.exe
*.dll
*.lib
*.app
*.out
*.so
*.dylib

# =============================
# Intermediate / cache
# =============================
Intermediate/
DerivedDataCache/
Saved/
*.log

# =============================
# Unreal precompiled assets
# =============================
*_BuiltData.uasset

# =============================
# Plugins
# =============================
Plugins/**/Binaries/
Plugins/**/Intermediate/

# =============================
# Optional generated asset sources
# =============================
SourceArt/**/*.png
SourceArt/**/*.tga

# =============================
# System files
# =============================
.DS_Store
Thumbs.db

# =============================
# Git LFS for large assets
# =============================
*.uasset filter=lfs diff=lfs merge=lfs -text
*.umap   filter=lfs diff=lfs merge=lfs -text
# Ignore Word documents
*.doc
*.docx